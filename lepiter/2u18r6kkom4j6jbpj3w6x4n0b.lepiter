					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-28T16:49:44.334424+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "HCBoQn8zTRmAKZr47WBuNA=="
				},
				"code" : "client := LocalClient mac.\rresult := client chat: {(AgentMessage user: 'How does TDD work?') asDictionary}.\r((STONJSON fromString: (result response)) at: #message) at: #content"
			},
